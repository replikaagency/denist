# =============================================================================
# Dental Reception AI — Environment Variables
# Copy to .env.local for local dev. Set these as Vercel environment variables
# for production. Never commit .env.local.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase  (REQUIRED)
# Found at: https://app.supabase.com/project/<your-project>/settings/api
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — server only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# JWT secret — server only, for signing patient realtime tokens.
# Found at: Project Settings > API > JWT Secret (same as Supabase Auth uses).
# Required for patient chat Realtime (staff replies without page refresh).
SUPABASE_JWT_SECRET=<your-jwt-secret>

# ---------------------------------------------------------------------------
# OpenAI  (REQUIRED)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o-mini)
# Supported values: gpt-4o-mini, gpt-4o, gpt-4.1, etc.
# Ensure the model supports response_format: { type: "json_object" }
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# App  (REQUIRED — must be your production URL in Vercel)
# Used for absolute URL construction and CORS. Do NOT leave as localhost.
# Example: https://dental-reception-ai.vercel.app
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Clinic configuration  (all optional — defaults are used if omitted)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_CLINIC_NAME is exposed to the browser and used in the chat UI.
# All others are server-only.
# NEXT_PUBLIC_CLINIC_NAME=Bright Smile Dental
# CLINIC_ADDRESS=742 Evergreen Terrace, Suite 200, Springfield, IL 62704
# CLINIC_PHONE=(555) 123-4567
# CLINIC_HOURS=Mon–Fri 8 AM–6 PM, Sat 9 AM–1 PM, Sun Closed
# CLINIC_EMERGENCY_PHONE=(555) 123-4567 ext. 9
# CLINIC_WEBSITE=https://brightsmile.example.com
# CLINIC_ACCEPTED_INSURANCE=Delta Dental,Cigna,Aetna,MetLife,Guardian
# CLINIC_SERVICES=Preventive (cleaning, exam, X-rays),Restorative (fillings, crowns, bridges)

# ---------------------------------------------------------------------------
# Resend — staff escalation email notifications  (optional)
# Sign up at https://resend.com. Verify your sending domain before going live.
# If any of these three vars are missing, escalation emails are silently skipped
# and the handoff is still created normally.
# ---------------------------------------------------------------------------
# RESEND_API_KEY=re_...
# ESCALATION_EMAIL_TO=recepcion@tudominio.com        # who receives the alert
# ESCALATION_EMAIL_FROM=notificaciones@tudominio.com  # verified sender in Resend

# ---------------------------------------------------------------------------
# Optional: Upstash Redis for production-grade global rate limiting
# Without this, rate limiting is in-memory and per-serverless-instance only.
# Get credentials at: https://console.upstash.com
# ---------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-token>
